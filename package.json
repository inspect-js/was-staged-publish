{
	"name": "was-staged-publish",
	"version": "0.0.0",
	"description": "Determine, from an npm packument, whether a published version was a staged publish (and thus 2FA-approved by a human)",
	"bin": "./bin.mjs",
	"main": false,
	"exports": {
		"./package.json": "./package.json"
	},
	"imports": {
		"#classify": "./classify.mjs",
		"#index": "./index.mjs",
		"#cli": "./cli.mjs"
	},
	"sideEffects": false,
	"scripts": {
		"prepack": "npmignore --auto --commentLines=autogenerated",
		"prepublishOnly": "safe-publish-latest",
		"prepublish": "not-in-publish || npm run prepublishOnly",
		"lint": "eslint .",
		"postlint": "tsc && evalmd README.md",
		"pretest": "npm run lint",
		"tests-only": "c8 tape 'test/**/*.mjs'",
		"test": "npm run tests-only",
		"posttest": "npx npm@\">= 10.2\" audit --production",
		"version": "auto-changelog && git add CHANGELOG.md",
		"postversion": "auto-changelog && git add CHANGELOG.md && git commit --no-edit --amend && git tag -f \"v$(node -e \"console.log(require('./package.json').version)\")\""
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/inspect-js/was-staged-publish.git"
	},
	"keywords": [
		"npm",
		"packument",
		"staged",
		"staged-publish",
		"2fa",
		"provenance",
		"supply-chain",
		"registry"
	],
	"author": "Jordan Harband <ljharb@gmail.com>",
	"funding": {
		"url": "https://github.com/sponsors/ljharb"
	},
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/inspect-js/was-staged-publish/issues"
	},
	"homepage": "https://github.com/inspect-js/was-staged-publish#readme",
	"dependencies": {
		"pacote": "^21.5.0",
		"pargs": "^1.3.1",
		"semver": "^7.8.3"
	},
	"devDependencies": {
		"@ljharb/eslint-config": "^22.2.3",
		"@ljharb/tsconfig": "^0.3.2",
		"@types/node": "^22.19.15",
		"@types/pacote": "^11.1.8",
		"@types/semver": "^7.7.1",
		"@types/tape": "^5.8.1",
		"auto-changelog": "^2.5.0",
		"c8": "^11.0.0",
		"encoding": "^0.1.13",
		"eslint": "^10.4.1",
		"evalmd": "^0.0.19",
		"in-publish": "^2.0.1",
		"jiti": "^0.0.0",
		"mock-property": "^1.1.0",
		"npmignore": "^0.3.5",
		"safe-publish-latest": "^2.0.0",
		"tape": "^5.9.0",
		"typescript": "next"
	},
	"engines": {
		"node": "^24.16 || ^26.3"
	},
	"auto-changelog": {
		"output": "CHANGELOG.md",
		"template": "keepachangelog",
		"unreleased": false,
		"commitLimit": false,
		"backfillLimit": false,
		"hideCredit": true,
		"autodetectMonorepoDisabled": false
	},
	"publishConfig": {
		"ignore": [
			".github/workflows",
			"eslint.config.mjs",
			"test",
			".nycrc"
		]
	}
}
